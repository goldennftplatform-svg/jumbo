{
  "name": "supersize",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "collection:download": "node scripts/download-collection.mjs",
    "collection:manifest": "node scripts/download-collection.mjs --manifest-only"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.11.0",
    "@upscalerjs/default-model": "^1.0.0-beta.17",
    "next": "^14.2.18",
    "pica": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "upscaler": "^1.0.0-beta.19"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/pica": "^9.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
